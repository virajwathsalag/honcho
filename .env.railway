# Honcho Environment - Railway Production
LOG_LEVEL=INFO
# Railway provides DATABASE_URL automatically - override the connection
# DB_CONNECTION_URI will be set in Railway Dashboard

# Gemini Free Tier (set in Railway Dashboard)
# LLM_GEMINI_API_KEY=your_gemini_api_key

# Core settings
MODEL_CONFIG__TRANSPORT=gemini
MODEL_CONFIG__MODEL=gemini-2.0-flash

# Embeddings
EMBEDDING_MODEL_CONFIG__TRANSPORT=gemini
EMBEDDING_MODEL_CONFIG__MODEL=gemini-embedding-001
EMBEDDING_VECTOR_DIMENSIONS=768

# Deriver
DERIVER_MODEL_CONFIG__TRANSPORT=gemini
DERIVER_MODEL_CONFIG__MODEL=gemini-2.0-flash

# Dialectic
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__TRANSPORT=gemini
DIALECTIC_LEVELS__minimal__MODEL_CONFIG__MODEL=gemini-2.0-flash

# Summary
SUMMARY_MODEL_CONFIG__TRANSPORT=gemini
SUMMARY_MODEL_CONFIG__MODEL=gemini-2.0-flash

# Dream (disabled for free tier)
DREAM_ENABLED=false

# Vector Store
VECTOR_STORE_TYPE=pgvector
VECTOR_STORE_MIGRATED=false